<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxx.scm.mapper.ProductCategoryMapper">

    <select id="findAll" resultType="com.xxx.scm.entity.ProductCategory">
        SELECT * FROM product_category ORDER BY category_id
    </select>

    <select id="findById" resultType="com.xxx.scm.entity.ProductCategory">
        SELECT * FROM product_category WHERE category_id = #{categoryId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="categoryId">
        INSERT INTO product_category(category_name, category_desc)
        VALUES(#{categoryName}, #{categoryDesc})
    </insert>

    <update id="update">
        UPDATE product_category
        SET category_name = #{categoryName}, category_desc = #{categoryDesc}
        WHERE category_id = #{categoryId}
    </update>

    <delete id="deleteById">
        DELETE FROM product_category WHERE category_id = #{categoryId}
    </delete>

    <select id="countProducts" resultType="int">
        SELECT COUNT(*) FROM product WHERE category_id = #{categoryId}
    </select>
</mapper>
